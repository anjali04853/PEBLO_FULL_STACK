# --- Server ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- Database ---
# Local: mongodb://127.0.0.1:27017/peblo-notes
# Atlas: mongodb+srv://<user>:<pass>@<cluster>/peblo-notes
DATABASE_URL=mongodb://127.0.0.1:27017/peblo-notes

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- AI Provider (Google Gemini) ---
# Get a free key at https://aistudio.google.com/app/apikey
# If left blank, the app falls back to a deterministic mock summariser.
LLM_API_KEY=
LLM_MODEL=gemini-1.5-flash
